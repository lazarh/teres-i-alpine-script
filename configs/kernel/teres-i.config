# Kernel config fragment for Olimex Teres-I (Allwinner A64 / sun50i-a64)
#
# Applied on top of the arm64 defconfig via merge_config.sh.
# Enables WiFi, display, audio, I2C peripherals, and power management
# specific to the Teres-I laptop hardware.
#
# Targeted at kernel 6.12.x LTS.

# ── Core system (Alpine/OpenRC needs these) ──────────────────────────────────
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_CGROUPS=y
CONFIG_FHANDLE=y

# ── WiFi — AP6212 / BCM43438 (SDIO) ─────────────────────────────────────────
# Enable both brcmfmac and rtl8723bs so the image works regardless of the
# WiFi module variant soldered on the board.
CONFIG_BRCMFMAC=m
CONFIG_BRCMFMAC_SDIO=y

# ── WiFi — RTL8723BS (SDIO, found on some Teres-I revisions) ─────────────────
CONFIG_RTL8723BS=m

# ── Bluetooth ────────────────────────────────────────────────────────────────
CONFIG_BT=m
CONFIG_BT_HCIUART=m
CONFIG_BT_HCIUART_H4=y
CONFIG_BT_HCIBTSDIO=m

# ── Display ──────────────────────────────────────────────────────────────────
# All display drivers are built-in (=y) so the native sun4i pipeline can probe
# during early kernel init without needing initramfs or rootfs-loaded modules.
# DRM_SIMPLEDRM uses the U-Boot framebuffer as a fallback until sun4i takes over.
CONFIG_DRM=y
CONFIG_DRM_SIMPLEDRM=y
CONFIG_DRM_DISPLAY_HELPER=y
CONFIG_DRM_SUN4I=y
# MIPI DSI controller — TCON0 outputs DSI which anx6345 converts to eDP
CONFIG_DRM_SUN6I_DSI=y
# Display Engine 2.0 mixer — required for Allwinner A64
CONFIG_DRM_SUN8I_MIXER=y
# TCON TOP multiplexer
CONFIG_DRM_SUN8I_TCON_TOP=y
# ANX6345 eDP bridge chip on the Teres-I panel
CONFIG_DRM_ANALOGIX_ANX6345=y
CONFIG_DRM_PANEL_SIMPLE=y
# DRM_PANEL_EDP must be =y (not =m) for the innolux,n116bge panel to be
# available during early boot when DRM driver probes
CONFIG_DRM_PANEL_EDP=y
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_PWM=y

# ── GPU (Lima — Mali-400 MP2 on A64) ─────────────────────────────────────────
CONFIG_DRM_LIMA=m

# ── Sound (Allwinner A64 audio codec + HDMI audio) ───────────────────────────
CONFIG_SND=y
CONFIG_SND_SOC=y
CONFIG_SND_SUN8I_CODEC=m
CONFIG_SND_SUN4I_I2S=m
CONFIG_SND_SUN8I_CODEC_ANALOG=m
CONFIG_SND_SOC_HDMI_CODEC=m

# ── Input — I2C keyboard controller and touchpad ─────────────────────────────
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_GPIO=y
CONFIG_INPUT_MOUSE=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_I2C_HID_OF=m

# ── Camera (CSI) ─────────────────────────────────────────────────────────────
CONFIG_VIDEO_V4L2=m
CONFIG_VIDEO_SUN6I_CSI=m

# ── Power management and battery ─────────────────────────────────────────────
CONFIG_MFD_AXP20X=y
CONFIG_MFD_AXP20X_RSB=y
CONFIG_REGULATOR_AXP20X=y
CONFIG_BATTERY_AXP20X=m
CONFIG_CHARGER_AXP20X=m
CONFIG_AXP20X_POWER=y
CONFIG_INPUT_AXP20X_PEK=m

# ── GPIO keys (power/lid switch) ─────────────────────────────────────────────
CONFIG_KEYBOARD_GPIO=y
CONFIG_INPUT_GPIO_KEYS=y

# ── PWM (fan / backlight control) ────────────────────────────────────────────
CONFIG_PWM=y
CONFIG_PWM_SUN4I=m

# ── Thermal management ───────────────────────────────────────────────────────
CONFIG_THERMAL=y
CONFIG_SUN8I_THERMAL=m

# ── USB ──────────────────────────────────────────────────────────────────────
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PLATFORM=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_EHCI_HCD_PLATFORM=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_OHCI_HCD_PLATFORM=y

# ── MMC / SD ─────────────────────────────────────────────────────────────────
CONFIG_MMC=y
CONFIG_MMC_SUNXI=y
CONFIG_MMC_BLOCK=y

# ── Real-time clock ──────────────────────────────────────────────────────────
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_SUN6I=y

# ── Watchdog ─────────────────────────────────────────────────────────────────
CONFIG_SUNXI_WATCHDOG=y

# ── Ethernet (USB dongle support) ────────────────────────────────────────────
CONFIG_USB_NET_DRIVERS=m
CONFIG_USB_USBNET=m
CONFIG_USB_RTL8152=m

# ── Framebuffer console ──────────────────────────────────────────────────────
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y
