From: Copilot <copilot@github.com>
Date: Mon, 10 Mar 2026 00:00:00 +0000
Subject: [PATCH] video: anx6345: enable AXP803 PMIC power via RSB on sunxi A64

On Olimex Teres-I (Allwinner A64 / sun50i), the ANX6345 eDP bridge
requires DLDO2 (dvdd25, 2.5V) and DLDO3 (dvdd12, 1.2V) from the AXP803
PMIC to be enabled before any I2C communication.  Mainline U-Boot for A64
uses CONFIG_SUNXI_NO_PMIC so the PMIC is never touched; DLDO2/3 stay off
by default.  This causes a blank screen on cold boot while warm reboots
work because Linux already enabled the supplies.

This patch enables direct AXP803 access via the Reduced Serial Bus (RSB)
from inside the ANX6345 driver before the bridge is activated:
  - DLDO2 set to 2.5V and enabled (dvdd25-supply)
  - DLDO3 set to 1.2V and enabled (dvdd12-supply)

To make the RSB wrapper functions (rsb_init, rsb_read/write,
rsb_set_device_address) available without the full AXP_PMIC_BUS framework,
the compilation guard in sun8i_rsb.c is relaxed to also include
CONFIG_SYS_I2C_SUN8I_RSB.

Signed-off-by: Copilot <copilot@github.com>
---
 configs/teres_i_defconfig          |  1 +
 drivers/i2c/sun8i_rsb.c            |  2 +-
 drivers/video/bridge/anx6345.c     | 81 +++++++++++++++++++++++++++++-
 3 files changed, 82 insertions(+), 2 deletions(-)

diff --git a/configs/teres_i_defconfig b/configs/teres_i_defconfig
--- a/configs/teres_i_defconfig
+++ b/configs/teres_i_defconfig
@@ -17,3 +17,4 @@
 CONFIG_VIDEO_BRIDGE=y
 CONFIG_VIDEO_BRIDGE_ANALOGIX_ANX6345=y
+CONFIG_SYS_I2C_SUN8I_RSB=y
diff --git a/drivers/i2c/sun8i_rsb.c b/drivers/i2c/sun8i_rsb.c
--- a/drivers/i2c/sun8i_rsb.c
+++ b/drivers/i2c/sun8i_rsb.c
@@ -137,7 +137,7 @@
-#if IS_ENABLED(CONFIG_AXP_PMIC_BUS)
+#if IS_ENABLED(CONFIG_AXP_PMIC_BUS) || IS_ENABLED(CONFIG_SYS_I2C_SUN8I_RSB)
 int rsb_read(const u16 runtime_addr, const u8 reg_addr, u8 *data)
diff --git a/drivers/video/bridge/anx6345.c b/drivers/video/bridge/anx6345.c
--- a/drivers/video/bridge/anx6345.c
+++ b/drivers/video/bridge/anx6345.c
@@ -14,6 +14,91 @@
 #include "../anx98xx-edp.h"
+#if IS_ENABLED(CONFIG_SYS_I2C_SUN8I_RSB)
+#include <asm/arch-sunxi/rsb.h>
+#endif
 
 #define DP_MAX_LINK_RATE		0x001
+
+/*
+ * AXP803 PMIC RSB constants for enabling ANX6345 power supplies.
+ * The ANX6345 requires dvdd25 (DLDO2, 2.5V) and dvdd12 (DLDO3, 1.2V)
+ * to be powered before any I2C communication.  On sunxi A64 boards the
+ * AXP803 PMIC sits on the RSB bus; U-Boot for A64 never enables the PMIC,
+ * so we do it here when RSB support is compiled in.
+ */
+#if IS_ENABLED(CONFIG_SYS_I2C_SUN8I_RSB)
+#define AXP_PMIC_DEVICE_ADDR		0x3a3
+#define AXP_PMIC_RUNTIME_ADDR		0x2d
+/* OUTPUT_CTRL2: DLDO1_EN=BIT(3) DLDO2_EN=BIT(4) DLDO3_EN=BIT(5) */
+#define AXP803_OUTPUT_CTRL2		0x12
+#define AXP803_DLDO2_CTRL		0x16
+#define AXP803_DLDO3_CTRL		0x17
+/* DLDO voltage: val = (mV - 700) / 100 */
+#define AXP803_DLDO_2500MV		((2500 - 700) / 100)	/* = 18 = 0x12 */
+#define AXP803_DLDO_1200MV		((1200 - 700) / 100)	/* = 5  = 0x05 */
+
+/**
+ * anx6345_sunxi_pmic_init() - Enable ANX6345 power supplies via AXP803 on RSB.
+ *
+ * Enables DLDO2 (dvdd25, 2.5V) and DLDO3 (dvdd12, 1.2V) on the AXP803 PMIC
+ * connected on the Reduced Serial Bus.  Safe to call multiple times; RSB init
+ * is idempotent.
+ */
+static int anx6345_sunxi_pmic_init(void)
+{
+	u8 val;
+	int ret;
+
+	ret = rsb_init();
+	if (ret) {
+		debug("%s: rsb_init failed: %d\n", __func__, ret);
+		return ret;
+	}
+
+	ret = rsb_set_device_address(AXP_PMIC_DEVICE_ADDR, AXP_PMIC_RUNTIME_ADDR);
+	if (ret) {
+		debug("%s: rsb_set_device_address failed: %d\n", __func__, ret);
+		return ret;
+	}
+
+	/* Set DLDO2 voltage to 2.5V (dvdd25-supply for ANX6345) */
+	ret = rsb_write(AXP_PMIC_RUNTIME_ADDR, AXP803_DLDO2_CTRL,
+			AXP803_DLDO_2500MV);
+	if (ret)
+		return ret;
+
+	/* Set DLDO3 voltage to 1.2V (dvdd12-supply for ANX6345) */
+	ret = rsb_write(AXP_PMIC_RUNTIME_ADDR, AXP803_DLDO3_CTRL,
+			AXP803_DLDO_1200MV);
+	if (ret)
+		return ret;
+
+	/* Enable DLDO2 (BIT 4) and DLDO3 (BIT 5) in OUTPUT_CTRL2 */
+	ret = rsb_read(AXP_PMIC_RUNTIME_ADDR, AXP803_OUTPUT_CTRL2, &val);
+	if (ret)
+		return ret;
+	val |= BIT(4) | BIT(5);
+	ret = rsb_write(AXP_PMIC_RUNTIME_ADDR, AXP803_OUTPUT_CTRL2, val);
+	if (ret)
+		return ret;
+
+	/* Allow supplies to stabilise before I2C access to ANX6345 */
+	mdelay(20);
+
+	return 0;
+}
+#endif /* CONFIG_SYS_I2C_SUN8I_RSB */
+
 struct anx6345_priv {
@@ -343,6 +343,18 @@ static int anx6345_enable(struct udevice *dev)
 	struct anx6345_priv *priv = dev_get_priv(dev);
 
+#if IS_ENABLED(CONFIG_SYS_I2C_SUN8I_RSB)
+	/*
+	 * Enable ANX6345 power supplies (dvdd25 / dvdd12) via the AXP803 PMIC
+	 * on sunxi A64 boards.  These are off by default and must be turned on
+	 * before any I2C communication with the bridge.
+	 */
+	ret = anx6345_sunxi_pmic_init();
+	if (ret)
+		debug("%s: PMIC init failed (%d), proceeding anyway\n",
+		      __func__, ret);
+#endif
+
 	/* Deassert reset and enable power */
 	ret = video_bridge_set_active(dev, true);
