--- a/drivers/video/bridge/anx6345.c	2019-10-08 00:14:02.000000000 +0300
+++ b/drivers/video/bridge/anx6345.c	2026-03-12 22:13:39.697851771 +0200
@@ -10,11 +10,74 @@
 #include <edid.h>
 #include <video_bridge.h>
 #include "../anx98xx-edp.h"
+#if IS_ENABLED(CONFIG_R_I2C_ENABLE)
+#include <asm/arch-sunxi/rsb.h>
+#endif
 
 #define DP_MAX_LINK_RATE		0x001
 #define DP_MAX_LANE_COUNT		0x002
 #define DP_MAX_LANE_COUNT_MASK		0x1f
 
+#if IS_ENABLED(CONFIG_R_I2C_ENABLE)
+#define AXP_PMIC_DEVICE_ADDR		0x3a3
+#define AXP_PMIC_RUNTIME_ADDR		0x2d
+#define AXP803_OUTPUT_CTRL2		0x12
+#define AXP803_DLDO2_CTRL		0x16
+#define AXP803_DLDO3_CTRL		0x17
+#define AXP803_DLDO_2500MV		((2500 - 700) / 100)
+#define AXP803_DLDO_1200MV		((1200 - 700) / 100)
+
+static int anx6345_sunxi_pmic_init(void)
+{
+	u8 val;
+	int ret;
+
+	ret = rsb_init();
+	if (ret) {
+		printf("ANX6345: rsb_init failed: %d\n", ret);
+		return ret;
+	}
+
+	ret = rsb_set_device_address(AXP_PMIC_DEVICE_ADDR, AXP_PMIC_RUNTIME_ADDR);
+	if (ret) {
+		printf("ANX6345: rsb_set_device_address failed: %d\n", ret);
+		return ret;
+	}
+
+	ret = rsb_write(AXP_PMIC_RUNTIME_ADDR, AXP803_DLDO2_CTRL,
+			AXP803_DLDO_2500MV);
+	if (ret) {
+		printf("ANX6345: DLDO2 voltage write failed: %d\n", ret);
+		return ret;
+	}
+
+	ret = rsb_write(AXP_PMIC_RUNTIME_ADDR, AXP803_DLDO3_CTRL,
+			AXP803_DLDO_1200MV);
+	if (ret) {
+		printf("ANX6345: DLDO3 voltage write failed: %d\n", ret);
+		return ret;
+	}
+
+	ret = rsb_read(AXP_PMIC_RUNTIME_ADDR, AXP803_OUTPUT_CTRL2, &val);
+	if (ret) {
+		printf("ANX6345: OUTPUT_CTRL2 read failed: %d\n", ret);
+		return ret;
+	}
+
+	val |= BIT(4) | BIT(5);
+	ret = rsb_write(AXP_PMIC_RUNTIME_ADDR, AXP803_OUTPUT_CTRL2, val);
+	if (ret) {
+		printf("ANX6345: OUTPUT_CTRL2 write failed: %d\n", ret);
+		return ret;
+	}
+
+	printf("ANX6345: OUTPUT_CTRL2 now 0x%02x\n", val);
+	mdelay(100);
+
+	return 0;
+}
+#endif
+
 struct anx6345_priv {
 	u8 edid[EDID_SIZE];
 };
